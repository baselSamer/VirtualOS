{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "shell",
			"label": "C/C++: Build Project-Ethos",
			"command": "C:/MinGW/bin/gcc.exe",
			"args": [
				"-fdiagnostics-color=always",
				"-g",
				"${workspaceFolder}/Src/main.c",
				"${workspaceFolder}/Src/emu/Console/Console.c",
				"${workspaceFolder}/Src/emu/Core/Emulator.c",
				"${workspaceFolder}/Src/emu/Core/Logger.c",
				"${workspaceFolder}/Src/emu/FIles/FIles.c",
				"${workspaceFolder}/Src/emu/Mem/Mem.c",
				"-o",
				"${workspaceFolder}/Src/main.exe"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": [
				"$gcc"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"detail": "Build Project-Ethos with all required source files"
		},
		{
			"type": "shell",
			"label": "C/C++: gcc.exe build active file",
			"command": "C:/MinGW/bin/gcc.exe",
			"args": [
				"-fdiagnostics-color=always",
				"-g",
				"${workspaceFolder}/Src/main.c",
				"${workspaceFolder}/Src/emu/Console/Console.c",
				"${workspaceFolder}/Src/emu/Core/Emulator.c",
				"${workspaceFolder}/Src/emu/Core/Logger.c",
				"${workspaceFolder}/Src/emu/FIles/FIles.c",
				"${workspaceFolder}/Src/emu/Mem/Mem.c",
				"-o",
				"${workspaceFolder}/Src/main.exe"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": [
				"$gcc"
			],
			"group": "build",
			"detail": "Compatibility task: builds full Project-Ethos instead of only active file"
		}
	]
}