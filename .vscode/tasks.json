{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Project Ethos",
            "type": "shell",
            "command": "${workspaceFolder}\\compile.cmd",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Runs compile.cmd to compile and link all project sources."
        }
    ]
}